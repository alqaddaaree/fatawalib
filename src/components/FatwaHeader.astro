---
import { formatHijriDate, formatGregorian } from '../utils/hijri';

interface FatwaHeaderProps {
  fatwa: {
    data: {
      id: string;
      title?: string;
      categories: string[];
      source_url?: string;
      translator?: string;
      reviewer?: string;
      date_issued?: string;
      date_issued_gregorian?: string;
      date_added: Date;
      audience?: string;
      tags?: string[];
    };
  };
  scholarInfo: {
    name: string;
    arabicName?: string;
  };
}

const { fatwa, scholarInfo } = Astro.props as FatwaHeaderProps;
const { id, title, categories, source_url, translator, reviewer, date_issued, date_issued_gregorian, date_added, audience, tags } = fatwa.data;
---

<header class="rounded-sm p-6 mb-8 relative overflow-hidden bg-accent text-page border border-emphasis">
  <!-- Arabic watermark -->
  <span class="absolute right-4 top-2 font-arabic text-6xl leading-none pointer-events-none select-none opacity-20">فتوى</span>

  <p class="text-xs font-sans font-medium uppercase tracking-widest mb-1 text-accent-hover">Fatwa #{id}</p>
  <h1 class="font-sans text-2xl font-medium mb-4 leading-snug pr-16 text-page">
    {title || `${scholarInfo.name}`}
    {scholarInfo.arabicName && (
      <span class="font-arabic text-lg ml-2 text-accent-hover">{scholarInfo.arabicName}</span>
    )}
  </h1>

  <div class="flex flex-wrap gap-2 mb-4">
    {categories.map((cat: string) => (
      <a
        href={`/category/${encodeURIComponent(cat.toLowerCase().replace(/\s+/g, '-'))}`}
        class="text-xs font-sans rounded-sm px-3 py-1 transition-colors uppercase font-medium bg-tag text-accent border border-emphasis"
        style="letter-spacing: 0.07em;"
      >
        {cat}
      </a>
    ))}
  </div>

  <dl class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-xs font-sans pt-4 border-t border-emphasis text-page/80">
    <div>
      <dt class="uppercase tracking-wider text-[10px] mb-0.5 text-page/50">Audience</dt>
      <dd>{audience || 'general'}</dd>
    </div>
    <div>
      <dt class="uppercase tracking-wider text-[10px] mb-0.5 text-page/50">Translator</dt>
      <dd>{translator || '—'}</dd>
    </div>
    {reviewer && (
      <div>
        <dt class="uppercase tracking-wider text-[10px] mb-0.5 text-page/50">Reviewer</dt>
        <dd>{reviewer}</dd>
      </div>
    )}
    <div>
      <dt class="uppercase tracking-wider text-[10px] mb-0.5 text-page/50">Date Issued (Hijri)</dt>
      <dd>{formatHijriDate(date_issued)}</dd>
    </div>
    <div>
      <dt class="uppercase tracking-wider text-[10px] mb-0.5 text-page/50">Date Issued (Gregorian)</dt>
      <dd>{formatGregorian(date_issued_gregorian || date_added)}</dd>
    </div>
  </dl>

  {tags && tags.length > 0 && (
    <p class="mt-4 text-xs text-page/70">Tags: {tags.join(', ')}</p>
  )}
</header>