---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allFatwas = await getCollection('fatwas');
const categoryMap = new Map<string, number>();
allFatwas.forEach(f => {
  f.data.categories.forEach((cat: string) => {
    categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
  });
});
const categories = [...categoryMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<Layout title="Categories">
  <div class="categories-header">
    <h1>Categories</h1>
    <p>Browse fatwas by category</p>
  </div>

  <div class="categories-grid">
    {categories.map(([name, count]) => (
      <a href={`/category/${name.toLowerCase().replace(/\s+/g, '-')}`} class="category-card">
        <span class="category-name">{name}</span>
        <span class="category-count">{count}</span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .categories-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-default);
    margin-bottom: 1rem;
  }
  .categories-header h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .categories-header p {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-muted);
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    padding: 0 2rem 2rem;
  }
  .category-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 0.5px solid var(--border-default);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }
  .category-card:hover {
    background: var(--bg-hover);
    border-color: var(--accent-light);
  }
  .category-name {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-primary);
  }
  .category-count {
    font-family: var(--font-ui);
    font-size: 11px;
    background: var(--bg-pill);
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 99px;
  }
</style>