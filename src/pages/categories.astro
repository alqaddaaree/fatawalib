---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allFatwas = await getCollection('fatwas');

// Build category → count map
const categoryMap = new Map<string, number>();
allFatwas.forEach((f) => {
  f.data.categories.forEach((cat) => {
    categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
  });
});

const categories = [...categoryMap.entries()]
  .sort((a, b) => b[1] - a[1]) // sort by count desc
  .map(([name, count]) => ({
    name,
    count,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
  }));
---

<Layout title="Categories">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="font-serif text-3xl mb-2" style="color: var(--text-primary);">Categories</h1>
    <p style="color: var(--text-secondary);" class="text-sm mb-8">Browse all fatwa categories. Numbers show how many fatwas are in each.</p>

    <div class="flex flex-wrap gap-3">
      {categories.map(({ name, count, slug }) => (
        <a
          href={`/category/${slug}`}
          class="group flex items-center gap-2 rounded-sm px-4 py-2.5 transition-all"
          style="background-color: var(--bg-card); border: 1px solid var(--border-default);"
        >
          <span class="font-sans text-sm transition-colors" style="color: var(--text-primary);">{name}</span>
          <span class="text-xs font-medium rounded-full px-2 py-0.5 transition-colors" style="background-color: var(--bg-tag); color: var(--text-muted);">
            {count}
          </span>
        </a>
      ))}
    </div>
  </div>
</Layout>
