---
import type { CollectionEntry } from "astro:content";

export interface Props {
  fatwa: CollectionEntry<"fatwas">;
  scholar?: { name: string };
}

const { fatwa, scholar } = Astro.props;
const slug = fatwa.id;
const { title, scholar: scholarId, date_added, translator, question, categories } = fatwa.data;
const categoryList = categories as string[];
const scholarName = scholar ? scholar.name.replace("Shaykh ", "") : scholarId;

function toPlainText(content: any): string {
  if (!content) return '';
  if (typeof content === 'string') return content.replace(/\n/g, ' ');
  function extract(node: any): string {
    if (!node) return '';
    if (typeof node === 'string') return node;
    if (Array.isArray(node)) return node.map(extract).join(' ');
    if (node.text) return node.text;
    if (node.children) return extract(node.children);
    return '';
  }
  try {
    return extract(content).replace(/\s+/g, ' ').trim();
  } catch {
    return '';
  }
}

function truncateText(input: string, max = 80): string {
  if (!input) return "";
  if (input.length <= max) return input;
  return `${input.slice(0, max).trimEnd()}...`;
}

const questionPlain = toPlainText(question);
const cardTitle = questionPlain ? truncateText(questionPlain, 100) : title || `Fatwa #${slug}`;
---

<article class="fatwa-card group rounded-sm p-5 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-card border border-border">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex-1 min-w-0">
      {categoryList.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-2">
          {categoryList.slice(0, 2).map(cat => (
            <a
              href={`/category/${encodeURIComponent(cat.toLowerCase().replace(/\s+/g, '-'))}`}
              class="cat-tag text-[9.5px] font-semibold uppercase tracking-wide px-2 py-0.5 rounded-sm bg-tag text-accent border border-emphasis"
            >
              {cat}
            </a>
          ))}
        </div>
      )}
      <a href={`/fatwa/${slug}`} class="block">
        <h2 class="card-title font-sans text-base font-medium leading-snug line-clamp-2 text-primary">
          {cardTitle}
        </h2>
      </a>
    </div>
    <span class="scholar-badge shrink-0 text-[10.5px] font-semibold px-2.5 py-1 rounded-sm whitespace-nowrap bg-accent text-page">
      {scholarName}
    </span>
  </div>
  <div class="card-footer flex items-center gap-2 text-[11px] pt-3 mt-1 text-muted border-t border-border">
    <span>Trans. {translator || '?'}</span>
    <span>•</span>
    <time datetime={date_added?.toISOString()}>
      {date_added?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
    <a href={`/fatwa/${slug}`} class="ml-auto font-medium text-accent">
      Read →
    </a>
  </div>
</article>