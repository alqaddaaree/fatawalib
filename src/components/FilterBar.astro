---
import { getCollection } from 'astro:content';

const scholars = (await getCollection('scholars')).map(s => ({ slug: s.id, name: s.data.name }));

export interface Props {
  activeScholar?: string;
  activeCategory?: string;
  allCategories: string[];
}
const { activeScholar, activeCategory, allCategories } = Astro.props;
---

<div class="fl-filters">
  <span class="fl-filters-label">Filter</span>
  <a href="/" class:list={['fl-btn', !activeScholar && !activeCategory && 'on']}>All</a>

  {scholars.map(s => (
    <a
      href={`/?scholar=${s.slug}`}
      class:list={['fl-btn', activeScholar === s.slug && 'on']}
    >
      {s.name.replace('Shaykh ', '')}
    </a>
  ))}

  {allCategories.map(cat => {
    const catSlug = cat.toLowerCase().replace(/\s+/g, '-');
    return (
      <a
        href={`/?category=${catSlug}`}
        class:list={['fl-btn', activeCategory === catSlug && 'on']}
      >
        {cat}
      </a>
    );
  })}
</div>

<style>
  .fl-filters {
    padding: 0.75rem 2rem;
    border-bottom: 1px solid var(--border-default);
    display: flex;
    gap: 0.5rem;
    align-items: center;
    background: var(--bg-page);
    flex-wrap: wrap;
  }
  .fl-filters-label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-right: 0.3rem;
  }
  .fl-btn {
    font-family: var(--font-ui);
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 99px;
    border: 1px solid var(--border-default);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: var(--transition);
    text-decoration: none;
    display: inline-block;
  }
  .fl-btn.on {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .fl-btn:not(.on):hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-pill);
  }
</style>