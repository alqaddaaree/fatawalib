---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FilterBar from '../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const allFatwas = (await getCollection('fatwas')).sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime());
const scholarCount = (await getCollection('scholars')).length;
const fatwaCount = allFatwas.length;
const categorySet = new Set<string>();
allFatwas.forEach(f => f.data.categories.forEach((c: string) => categorySet.add(c)));
const categoryCount = categorySet.size;
const allCategories = [...categorySet].sort();

const activeScholar = Astro.url.searchParams.get('scholar') || undefined;
const activeCategory = Astro.url.searchParams.get('category') || undefined;

const allScholars = await getCollection('scholars');
const scholarNameMap = new Map(allScholars.map(s => [s.id, s.data.name]));
---

<Layout title="Home">
  <Hero
    rulingsCount={fatwaCount}
    scholarsCount={scholarCount}
    categoriesCount={categoryCount}
    eyebrow="Islamic Legal Rulings"
    title="A Scholarly Archive of Verified Fatwas"
    subtitle="Authentic religious rulings from trusted scholars across traditions — carefully collected, categorised, and made readable."
  />

  <!-- Search section -->
  <div class="search-section">
    <div class="search-input-wrapper">
      <input
        type="text"
        id="home-search"
        placeholder="Search fatwas…"
        autocomplete="off"
        class="search-input"
      />
    </div>

    <div class="filter-pills">
      <div class="filter-section">
        <span class="filter-label">Scholar</span>
        <div class="filter-buttons">
          <button class="filter-pill" data-filter-type="scholar" data-filter-value="">All</button>
          {allScholars.map(s => (
            <button class="filter-pill" data-filter-type="scholar" data-filter-value={s.id}>
              {s.data.name.replace('Shaykh ', '')}
            </button>
          ))}
        </div>
      </div>
      <div class="filter-section">
        <span class="filter-label">Category</span>
        <div class="filter-buttons">
          <button class="filter-pill" data-filter-type="category" data-filter-value="">All</button>
          {allCategories.map(cat => (
            <button class="filter-pill" data-filter-type="category" data-filter-value={cat.toLowerCase().replace(/\s+/g, '-')}>
              {cat}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Original filter bar (scholar/category pills) – optional, can be removed later -->
  <div class="filter-bar-placeholder" style="display: none;">
    <FilterBar
      allCategories={allCategories}
      activeScholar={activeScholar}
      activeCategory={activeCategory}
    />
  </div>

  <div id="fatwa-grid" class="px-4 sm:px-6 lg:px-8">
    <ul class="fatwa-registry">
      {allFatwas.map(fatwa => {
        const fullName = scholarNameMap.get(fatwa.data.scholar) || fatwa.data.scholar;
        const shortName = fullName.split(' ').pop();
        return (
          <li
            class="fatwa-registry-item"
            data-scholar={fatwa.data.scholar}
            data-categories={fatwa.data.categories.map((c: string) => c.toLowerCase().replace(/\s+/g, '-')).join(',')}
            data-title={fatwa.data.title || `Fatwa #${fatwa.id}`}
            data-body={fatwa.data.question ? fatwa.data.question.replace(/\n/g, ' ') : ''}
            onclick={`window.location.href='/fatwa/${fatwa.id}'`}
            style="cursor: pointer;"
          >
            <span class="fatwa-registry-date">{fatwa.data.date_added.toLocaleDateString()}</span>
            <div class="fatwa-registry-title-wrap">
              <span class="fatwa-registry-title">{fatwa.data.title || `Fatwa #${fatwa.id}`}</span>
              {fatwa.data.categories.length > 0 && (
                <span class="fl-cat-pill">{fatwa.data.categories[0]}</span>
              )}
            </div>
            <span class="fatwa-registry-scholar">{shortName}</span>
          </li>
        );
      })}
    </ul>
  </div>

  <p id="empty-state" class="hidden text-center py-12 text-[var(--text-muted)]">No fatwas match this filter.</p>
</Layout>

<script>
  // Combine search text and filter pills
  const searchInput = document.getElementById('home-search') as HTMLInputElement;
  const items = document.querySelectorAll<HTMLLIElement>('.fatwa-registry-item');
  const emptyState = document.getElementById('empty-state');
  let activeFilters = { scholar: '', category: '' };

  function getFilterValue(type: string): string {
    const activeBtn = document.querySelector(`.filter-pill[data-filter-type="${type}"].active`);
    return activeBtn?.getAttribute('data-filter-value') || '';
  }

  function setActiveFilter(type: string, value: string) {
    document.querySelectorAll(`.filter-pill[data-filter-type="${type}"]`).forEach(btn => {
      const btnVal = btn.getAttribute('data-filter-value');
      if (btnVal === value) btn.classList.add('active');
      else btn.classList.remove('active');
    });
  }

  function applyFilters() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const scholarFilter = getFilterValue('scholar');
    const categoryFilter = getFilterValue('category');

    let visible = 0;
    items.forEach(item => {
      const matchesScholar = !scholarFilter || item.dataset.scholar === scholarFilter;
      const matchesCategory = !categoryFilter || (item.dataset.categories ?? '').split(',').includes(categoryFilter);
      const matchesText = !searchTerm || 
        (item.dataset.title?.toLowerCase().includes(searchTerm)) ||
        (item.dataset.body?.toLowerCase().includes(searchTerm));

      const show = matchesScholar && matchesCategory && matchesText;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
  }

  // Search input debounce
  let debounceTimer: ReturnType<typeof setTimeout>;
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(applyFilters, 220);
    });
  }

  // Filter pill clicks
  document.querySelectorAll('.filter-pill').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const type = btn.getAttribute('data-filter-type');
      const value = btn.getAttribute('data-filter-value');
      if (type === 'scholar') {
        // Toggle: if already active, set to empty (All); else set to this value
        const current = getFilterValue('scholar');
        const newValue = (current === value) ? '' : value;
        setActiveFilter('scholar', newValue);
      } else if (type === 'category') {
        const current = getFilterValue('category');
        const newValue = (current === value) ? '' : value;
        setActiveFilter('category', newValue);
      }
      applyFilters();
    });
  });

  // Initialize active filters from URL params if any
  const urlParams = new URLSearchParams(window.location.search);
  const scholarParam = urlParams.get('scholar');
  const categoryParam = urlParams.get('category');
  if (scholarParam) setActiveFilter('scholar', scholarParam);
  if (categoryParam) setActiveFilter('category', categoryParam);
  applyFilters();

  // Also keep existing filter bar hidden – we're replacing it with the new pills
  // The old FilterBar component is now hidden (display: none) to avoid duplication.
</script>

<style>
  .search-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 1rem;
  }
  .search-input-wrapper {
    max-width: 560px;
    margin: 0 auto 1.5rem;
  }
  .search-input {
    width: 100%;
    padding: 10px 1.25rem;
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: 99px;
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-light);
  }
  .filter-pills {
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--border-default);
    padding-top: 1rem;
  }
  .filter-section {
    margin-bottom: 0.75rem;
  }
  .filter-label {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    width: 70px;
    vertical-align: top;
    padding-top: 0.25rem;
  }
  .filter-buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .filter-pill {
    font-family: var(--font-ui);
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 99px;
    border: 1px solid var(--border-default);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition), color var(--transition);
  }
  .filter-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-pill);
  }
  .filter-pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
</style>