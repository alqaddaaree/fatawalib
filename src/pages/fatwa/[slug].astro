---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FatwaHeader from '../../components/FatwaHeader.astro';
import SourceBlock from '../../components/SourceBlock.astro';
import ShareMenu from '../../components/ShareMenu.astro';   // new component
import RelatedFatwas from '../../components/RelatedFatwas.astro';
import MarkdocRenderer from '../../components/MarkdocRenderer.astro';

export async function getStaticPaths() {
  const fatwas = await getCollection('fatwas');
  return fatwas.map((fatwa) => ({
    params: { slug: fatwa.id },
    props:  { fatwa },
  }));
}

// Fetch all scholars for the lookup map
const allScholars = await getCollection('scholars');
const scholarMap = new Map<string, any>(allScholars.map(s => [s.id, s.data]));

function getScholar(scholarId: string) {
  const scholar = scholarMap.get(scholarId);
  if (!scholar) {
    return {
      name: scholarId,
      arabicName: '',
      lifespan: '',
      bio: '',
    };
  }
  return scholar;
}

function toPlainText(content: any): string {
  if (!content) return '';
  if (typeof content === 'string') return content.replace(/\n/g, ' ');
  function extract(node: any): string {
    if (!node) return '';
    if (typeof node === 'string') return node;
    if (Array.isArray(node)) return node.map(extract).join(' ');
    if (node.text) return node.text;
    if (node.children) return extract(node.children);
    return '';
  }
  try {
    return extract(content).replace(/\s+/g, ' ').trim();
  } catch {
    return '';
  }
}

function truncateText(input: string, max = 100): string {
  if (!input) return '';
  if (input.length <= max) return input;
  return `${input.slice(0, max).trimEnd()}...`;
}

const { slug } = Astro.params;
let fatwa = Astro.props.fatwa as CollectionEntry<'fatwas'> | undefined;
if (!fatwa) {
  fatwa = await getEntry('fatwas', slug!);
}
if (!fatwa) {
  return Astro.redirect('/404');
}

const currentId = fatwa.id;
const { title, scholar, categories, source_url, translator, reviewer, date_issued, date_issued_gregorian, date_added, arabic_question, arabic_answer, audience, tags, question, answer, footnotes, notes } = fatwa.data;
const scholarInfo = getScholar(scholar);

const questionPlain = toPlainText(question);
const answerPlain = toPlainText(answer);
const generatedDescription = answerPlain
  ? `${truncateText(answerPlain, 160)}...`
  : `A translated fatwa by ${scholarInfo.name}, covering: ${categories.join(', ')}.`;

// Related fatwas
const allFatwas = await getCollection('fatwas');
const relatedItems = allFatwas
  .filter(entry => entry.id !== currentId && entry.data.categories.some((cat: string) => categories.includes(cat)))
  .sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime())
  .slice(0, 4)
  .map(entry => ({
    fatwa: entry,
    scholar: getScholar(entry.data.scholar),
    question: truncateText(toPlainText(entry.data.question), 100),
  }));

const qaSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'QAPage',
  mainEntity: {
    '@type': 'Question',
    name: questionPlain || `Fatwa #${currentId}`,
    text: questionPlain || `Fatwa #${currentId}`,
    answerCount: 1,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answerPlain || 'Refer to the fatwa page for the complete answer.',
    },
  },
});

// Determine if Arabic content exists
const hasArabic = !!(arabic_question || arabic_answer);
// Determine if English content exists (always true, but we keep symmetry)
const hasEnglish = true;
// Grid column classes: if both, use 1fr 1fr; if only one, use 1fr
const gridCols = hasArabic && hasEnglish ? 'grid-cols-1 lg:grid-cols-2' : 'grid-cols-1';
---

<Layout
  title={`Fatwa — ${scholarInfo.name}`}
  description={generatedDescription}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={qaSchema}></script>
  </Fragment>

  <div id="top" class="max-w-5xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs font-sans mb-6 flex items-center gap-2 text-muted">
      <a href="/" class="hover:text-accent transition-colors">Home</a>
      <span>/</span>
      <a href={`/scholar/${scholar}`} class="hover:text-accent transition-colors">{scholarInfo.name}</a>
      <span>/</span>
      <span class="text-primary">{title || `Fatwa #${currentId}`}</span>
    </nav>

    <FatwaHeader fatwa={fatwa} scholarInfo={scholarInfo} />

    <!-- Share menu instead of old ShareBar -->
    <ShareMenu id={currentId} title={title || `Fatwa #${currentId}`} question={questionPlain} answer={answerPlain} />

    <!-- Bilingual two‑column layout (conditional columns) -->
    <div class={`grid ${gridCols} gap-10 mt-10`}>
      <!-- English column (always shown) -->
      <div class="space-y-8">
        <div class="prose prose-stone dark:prose-invert max-w-none">
          <h2 class="font-sans text-xl font-medium text-primary border-b border-border pb-2 mb-4">Question</h2>
          <MarkdocRenderer content={question} />
        </div>
        <div class="prose prose-stone dark:prose-invert max-w-none">
          <h2 class="font-sans text-xl font-medium text-primary border-b border-border pb-2 mb-4">Answer</h2>
          <MarkdocRenderer content={answer} />
        </div>
      </div>

      <!-- Arabic column (only if content exists) -->
      {hasArabic && (
        <div class="space-y-8" dir="rtl">
          {arabic_question && (
            <div class="prose prose-stone dark:prose-invert max-w-none">
              <h2 class="font-arabic text-xl font-medium text-primary border-b border-border pb-2 mb-4">السؤال</h2>
              <MarkdocRenderer content={arabic_question} />
            </div>
          )}
          {arabic_answer && (
            <div class="prose prose-stone dark:prose-invert max-w-none">
              <h2 class="font-arabic text-xl font-medium text-primary border-b border-border pb-2 mb-4">الجواب</h2>
              <MarkdocRenderer content={arabic_answer} />
            </div>
          )}
        </div>
      )}
    </div>

    <!-- Footnotes and Notes (if any) -->
    {footnotes && (
      <div class="mt-10 pt-6 border-t border-border">
        <h2 class="font-sans text-xl font-medium text-primary mb-3">Footnotes</h2>
        <div class="prose prose-stone dark:prose-invert max-w-none">
          <MarkdocRenderer content={footnotes} />
        </div>
      </div>
    )}

    {notes && (
      <div class="mt-8 pt-6 border-t border-border">
        <h2 class="font-sans text-xl font-medium text-primary mb-3">Notes</h2>
        <div class="prose prose-stone dark:prose-invert max-w-none">
          <MarkdocRenderer content={notes} />
        </div>
      </div>
    )}

    <!-- Single SourceBlock (no duplicate) -->
    <SourceBlock source_url={source_url} />

    <RelatedFatwas items={relatedItems} />

    <!-- Footer links (moved from SourceBlock duplication) -->
    <div class="mt-10 pt-6 border-t border-border">
      <div class="mt-6 flex items-center justify-between gap-3 flex-wrap">
        <a href="/" class="text-sm text-accent hover:text-accent-hover font-sans font-medium transition-colors">← Back to all fatwas</a>
        <a href={`mailto:fatawalib@example.com?subject=Report%20a%20mistake%20in%20Fatwa%20%23${currentId}`} class="text-xs text-muted hover:text-accent transition-colors">
          Report a mistake
        </a>
      </div>
    </div>

    <a
      href="#top"
      class="fixed bottom-5 right-5 z-30 print:hidden inline-flex items-center justify-center rounded-full bg-accent hover:bg-accent-hover text-page shadow-lg w-10 h-10 transition-colors"
      aria-label="Back to top"
    >
      ↑
    </a>
  </div>
</Layout>