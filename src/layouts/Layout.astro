---
import "/src/styles/global.css";
export interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Fatawa Library – Islamic legal rulings in translation",
} = Astro.props;
const siteOrigin = Astro.site ?? new URL("https://fatawalib.com");
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title} – Fatawa Library</title>
    <slot name="head" />
  </head>
  <body>
    <header class="fl-nav">
      <a href="/" class="fl-logo">
        <span class="fl-logo-dot"></span>
        Fatawa Library
      </a>
      <div class="fl-nav-links">
        <a href="/" class:list={["", currentPath === "/" && "active"]}>Browse</a
        >
        <a
          href="/scholars"
          class:list={["", currentPath === "/scholars" && "active"]}>Scholars</a
        >
        <a
          href="/categories"
          class:list={["", currentPath === "/categories" && "active"]}
          >Categories</a
        >
        <a
          href="/search"
          class:list={["", currentPath === "/search" && "active"]}>Search</a
        >
        <a href="/about" class:list={["", currentPath === "/about" && "active"]}
          >About</a
        >
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="fl-footer">
      <p>
        © {new Date().getFullYear()} Fatawa Library – translations for educational
        purposes
      </p>
    </footer>
  </body>
</html>

<style>
  .fl-nav {
    background: var(--bg-page);
    border-bottom: 2px solid var(--accent-light);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
  }
  .fl-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--text-primary);
  }
  .fl-logo:hover {
    text-decoration: none;
  }
  .fl-logo-dot {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }
  .fl-nav-links {
    display: flex;
    gap: 1.5rem;
  }
  .fl-nav-links a {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 400;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .fl-nav-links a.active {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px;
  }
  .fl-nav-links a:hover {
    color: var(--accent);
  }

  /* Footer positioning – keeps footer at bottom */
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    margin: 0;
  }
  main {
    flex: 1;
  }

  .fl-footer {
    background: var(--bg-page);
    border-top: 1px solid var(--border-default);
    padding: 2rem;
    text-align: center;
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
