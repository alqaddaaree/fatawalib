---
import { getCollection } from 'astro:content';

// Fetch scholars from the collection and build a simple array
const scholarsData = await getCollection('scholars');
const scholars = scholarsData.map(s => ({
  id: s.id,
  name: s.data.name,
}));

export interface Props {
  activeScholar?: string;
  activeCategory?: string;
  allCategories: string[];
}

const { activeScholar, activeCategory, allCategories } = Astro.props;
---

<div data-filter-bar class="rounded-sm p-4 mb-6 flex flex-col sm:flex-row gap-4 items-start sm:items-center" style="background-color: var(--bg-card); border: 1px solid var(--border-default); color: var(--text-primary);">

  <!-- Scholar filter -->
  <div class="flex flex-wrap gap-2 flex-1">
    <a
      data-scholar-link=""
      href="/"
      class:list={[
        'text-xs font-medium px-3 py-1.5 rounded-sm border transition-colors font-sans',
        !activeScholar
          ? 'text-white'
          : 'border-current text-stone-600 hover:border-teal-800 hover:text-teal-800',
      ]}
      style={!activeScholar ? `background-color: var(--accent); color: var(--bg-page); border: 1px solid var(--accent);` : `border-color: var(--border-default); color: var(--text-secondary);`}
    >
      All Scholars
    </a>
    {scholars.map((s) => (
      <a
        data-scholar-link={s.id}
        href={`/?scholar=${s.id}`}
        class:list={[
          'text-xs font-medium px-3 py-1.5 rounded-sm border transition-colors font-sans',
          activeScholar === s.id
            ? 'text-white'
            : 'border-current text-stone-600 hover:border-teal-800 hover:text-teal-800',
        ]}
        style={activeScholar === s.id ? `background-color: var(--accent); color: var(--bg-page); border: 1px solid var(--accent);` : `border-color: var(--border-default); color: var(--text-secondary);`}
      >
        {s.name.replace('Shaykh ', '')}
      </a>
    ))}
  </div>

  <!-- Category filter -->
  {allCategories.length > 0 && (
    <div class="shrink-0">
      <select
        id="category-filter"
        class="text-xs font-sans px-3 py-1.5 focus:outline-none cursor-pointer rounded-sm"
        style="background-color: var(--bg-page); color: var(--text-primary); border: 1px solid var(--border-default);"
      >
        <option value="">All Categories</option>
        {allCategories.map((cat) => (
          <option
            value={encodeURIComponent(cat.toLowerCase().replace(/\s+/g, '-'))}
            selected={activeCategory === cat.toLowerCase().replace(/\s+/g, '-')}
          >
            {cat}
          </option>
        ))}
      </select>
    </div>
  )}
</div>

<script>
  const params = new URLSearchParams(window.location.search);
  const scholar = params.get('scholar') ?? '';
  const category = params.get('category') ?? '';

  document.querySelectorAll<HTMLAnchorElement>('[data-scholar-link]').forEach((link) => {
    const scholarId = link.dataset.scholarLink ?? '';
    const next = new URLSearchParams();
    if (scholarId) next.set('scholar', scholarId);
    if (category) next.set('category', category);
    link.href = next.toString() ? `/?${next.toString()}` : '/';
  });

  const select = document.getElementById('category-filter') as HTMLSelectElement | null;
  if (select) {
    const baseParams = new URLSearchParams();
    if (scholar) baseParams.set('scholar', scholar);
    select.dataset.base = baseParams.toString() ? `/?${baseParams.toString()}` : '/?';
    select.value = category;
    select.addEventListener('change', () => {
      const base = select.dataset.base ?? '/?';
      const categoryPart = select.value ? `${base.includes('?') ? '&' : '?'}category=${select.value}` : '';
      window.location.href = `${base}${categoryPart}`.replace('/?&', '/?');
    });
  }
</script>