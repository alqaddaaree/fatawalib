---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FatwaCard from '../../components/FatwaCard.astro';

export async function getStaticPaths() {
  const allScholars = await getCollection('scholars');
  const allFatwas = await getCollection('fatwas');
  
  return allScholars.map((scholarEntry) => {
    const scholarId = scholarEntry.id;
    return {
      params: { scholar: scholarId },
      props: {
        scholar: scholarEntry.data,
        fatwas: allFatwas
          .filter((f) => f.data.scholar === scholarId)
          .sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime()),
      },
    };
  });
}

const { scholar, fatwas } = Astro.props;
---

<Layout title={scholar.name} description={scholar.bio}>
  <div class="max-w-5xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="rounded-sm p-8 mb-8 flex flex-col sm:flex-row gap-6 items-start" style="background-color: var(--accent); color: var(--bg-page);">
      <div class="flex-1">
        <p class="font-arabic text-5xl mb-2 leading-none" style="color: var(--accent-hover);">{scholar.arabicName}</p>
        <h1 class="font-serif text-2xl mb-1">{scholar.name}</h1>
        <p class="text-sm font-sans mb-4" style="color: rgba(245, 241, 234, 0.6);">{scholar.lifespan}</p>
        <p class="text-sm max-w-xl" style="color: rgba(245, 241, 234, 0.8);">{scholar.bio}</p>
      </div>
      <div class="text-center rounded-sm px-8 py-5 shrink-0" style="background-color: var(--accent-hover);">
        <p class="font-serif text-4xl" style="color: var(--accent-hover); opacity: 0.3;">{fatwas.length}</p>
        <p class="text-xs font-sans mt-1" style="color: rgba(245, 241, 234, 0.6);">Translated Fatwas</p>
      </div>
    </div>

    <!-- Fatwas grid -->
    {fatwas.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {fatwas.map((fatwa) => <FatwaCard fatwa={fatwa} scholar={scholar} />)}
      </div>
    ) : (
      <p class="text-center py-16 font-serif text-xl" style="color: var(--text-secondary);">No fatwas yet for this scholar.</p>
    )}

    <div class="mt-8">
      <a href="/scholars" class="text-sm font-sans font-medium transition-colors" style="color: var(--accent);">← All Scholars</a>
    </div>
  </div>
</Layout>
