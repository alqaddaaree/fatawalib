---
interface Props {
  rulingsCount: number;
  scholarsCount: number;
  categoriesCount: number;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}

const {
  rulingsCount,
  scholarsCount,
  categoriesCount,
  eyebrow = 'Islamic Legal Rulings',
  title = 'A Scholarly Archive of Verified Fatwas',
  subtitle = 'Authentic religious rulings from trusted scholars across traditions — carefully collected, categorised, and made readable.'
} = Astro.props;
---

<div class="fl-hero">
  <div class="fl-hero-eyebrow">{eyebrow}</div>
  <h1>{title}</h1>
  <div class="fl-hero-sub-row">
    <p class="fl-hero-sub">{subtitle}</p>
    <div class="fl-stats">
      <div class="fl-stat">
        <div class="fl-stat-num">{rulingsCount.toLocaleString()}</div>
        <div class="fl-stat-label">Rulings</div>
      </div>
      <div class="fl-stat">
        <div class="fl-stat-num">{scholarsCount.toLocaleString()}</div>
        <div class="fl-stat-label">Scholars</div>
      </div>
      <div class="fl-stat">
        <div class="fl-stat-num">{categoriesCount.toLocaleString()}</div>
        <div class="fl-stat-label">Categories</div>
      </div>
    </div>
  </div>
</div>

<style>
  .fl-hero {
    padding: 2.5rem 2rem 1.8rem;
    border-bottom: 1px solid var(--border-default);
  }
  .fl-hero-eyebrow {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
  }
  .fl-hero h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--text-primary);
    margin: 0 0 1rem;
    max-width: 520px;
  }
  .fl-hero-sub-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
  }
  .fl-hero-sub {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0;
  }
  .fl-stats {
    display: flex;
    gap: 2rem;
    flex-shrink: 0;
  }
  .fl-stat-num {
    font-size: 20px;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: -0.01em;
  }
  .fl-stat-label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: 2px;
  }
  @media (max-width: 720px) {
    .fl-hero-sub-row {
      flex-direction: column;
      align-items: flex-start;
    }
    .fl-stats {
      margin-top: 0.5rem;
    }
  }
</style>