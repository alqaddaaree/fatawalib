---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allFatwas = await getCollection('fatwas');

// Build category → count map
const categoryMap = new Map<string, number>();
allFatwas.forEach((f) => {
  f.data.categories.forEach((cat) => {
    categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
  });
});

const categories = [...categoryMap.entries()]
  .sort((a, b) => b[1] - a[1]) // sort by count desc
  .map(([name, count]) => ({
    name,
    count,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
  }));
---

<Layout title="Categories">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="font-serif text-3xl text-teal-900 mb-2">Categories</h1>
    <p class="text-stone-500 text-sm mb-8">Browse all fatwa categories. Numbers show how many fatwas are in each.</p>

    <div class="flex flex-wrap gap-3">
      {categories.map(({ name, count, slug }) => (
        <a
          href={`/category/${slug}`}
          class="group flex items-center gap-2 bg-white border border-sand-200 rounded-xl px-4 py-2.5 hover:border-teal-800/40 hover:shadow-sm transition-all"
        >
          <span class="font-sans text-sm text-stone-700 group-hover:text-teal-900 transition-colors">{name}</span>
          <span class="text-xs font-medium bg-cream-100 text-stone-500 rounded-full px-2 py-0.5 group-hover:bg-teal-900 group-hover:text-white transition-colors">
            {count}
          </span>
        </a>
      ))}
    </div>
  </div>
</Layout>
