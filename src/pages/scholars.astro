---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allScholars = await getCollection('scholars');
const allFatwas = await getCollection('fatwas');

const counts: Record<string, number> = {};
for (const scholar of allScholars) {
  counts[scholar.id] = 0;
}
for (const fatwa of allFatwas) {
  counts[fatwa.data.scholar]++;
}
---

<Layout title="Scholars">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="font-serif text-3xl mb-2" style="color: var(--text-primary);">Scholars</h1>
    <p style="color: var(--text-secondary);" class="text-sm mb-8">Browse fatwas by scholar. Click a card to see all their rulings.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {allScholars.map((scholar) => {
        const scholarId = scholar.id; // filename slug, e.g. "ibn-baz"
        const s = scholar.data;
        return (
          <a
            href={`/scholar/${scholarId}`}
            class="group rounded-sm p-6 flex flex-col gap-3 transition-all"
            style="background-color: var(--bg-card); border: 1px solid var(--border-default); color: var(--text-primary);"
          >
            <div class="flex items-center justify-between">
              <div>
                <p class="font-arabic text-2xl leading-none mb-1" style="color: var(--accent-hover);">{s.arabicName}</p>
                <h2 class="font-serif text-lg transition-colors" style="color: var(--text-primary);">{s.name}</h2>
                <p class="text-xs font-sans" style="color: var(--text-muted);">{s.lifespan}</p>
              </div>
              <span class="flex items-center justify-center shrink-0 w-12 h-12 text-sm font-sans font-semibold rounded-sm" style="background-color: var(--accent); color: var(--bg-page);">
                {counts[scholarId]}
              </span>
            </div>
            <p class="text-sm line-clamp-3" style="color: var(--text-secondary);">{s.bio}</p>
            <span class="text-xs font-sans font-medium transition-colors" style="color: var(--accent);">
              View {counts[scholarId]} fatwa{counts[scholarId] !== 1 ? 's' : ''} →
            </span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>