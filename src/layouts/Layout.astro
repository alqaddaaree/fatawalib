---
export interface Props {
  title:       string;
  description?: string;
}

const { title, description = 'Fatawa Library is a curated archive of Islamic fatwas from senior scholars.' } = Astro.props;
const siteOrigin = Astro.site ?? new URL('https://fatawalib.com');
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL('/og-image-placeholder.jpg', siteOrigin);
---

<!doctype html>
<html lang="en" dir="auto">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImage.toString()} />

    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <title>{title} — Fatawa Library</title>
    <style>@import url('/src/styles/global.css');</style>
    <slot name="head" />
  </head>

  <body class="bg-cream-50 text-stone-800 dark:bg-stone-950 dark:text-stone-100 font-sans min-h-screen flex flex-col">

    <!-- Top bar -->
    <header class="bg-teal-900 text-cream-100 dark:bg-stone-900 dark:text-stone-100 shadow-md">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4 flex-wrap">
        <a href="/" class="flex flex-col leading-tight group">
          <span class="font-arabic text-2xl text-gold-400 group-hover:text-gold-300 transition-colors">مكتبة الفتاوى</span>
          <span class="font-serif text-base tracking-wide text-cream-200 dark:text-stone-300 group-hover:text-white transition-colors">Fatawa Library</span>
        </a>
        <nav class="flex items-center gap-3 sm:gap-4 text-sm font-sans font-medium">
          <a href="/" class="text-cream-200 dark:text-stone-300 hover:text-white transition-colors">Home</a>
          <a href="/scholars" class="text-cream-200 dark:text-stone-300 hover:text-white transition-colors">Scholars</a>
          <a href="/categories" class="text-cream-200 dark:text-stone-300 hover:text-white transition-colors">Categories</a>
          <a href="/about" class="text-cream-200 dark:text-stone-300 hover:text-white transition-colors">About</a>

          <form action="/search" method="get" class="hidden md:flex items-center gap-1">
            <input
              type="search"
              name="q"
              placeholder="Search fatwas"
              class="w-44 lg:w-52 bg-cream-50/95 text-stone-800 placeholder:text-stone-500 border border-sand-200 rounded-md px-2.5 py-1.5 text-xs focus:outline-none focus:border-gold-400"
            />
            <button
              type="submit"
              class="bg-gold-500 hover:bg-gold-400 text-white px-3 py-1.5 rounded text-xs transition-colors"
              aria-label="Search"
            >
              Search
            </button>
          </form>

          <a href="/search" class="md:hidden text-cream-200 dark:text-stone-300 hover:text-white transition-colors" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="7" />
              <path d="m20 20-3.5-3.5" />
            </svg>
          </a>

          <button
            id="theme-toggle"
            type="button"
            class="inline-flex items-center justify-center rounded-md border border-cream-100/30 dark:border-stone-600 p-1.5 text-cream-200 dark:text-stone-300 hover:text-white hover:border-cream-100/60 transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg data-theme-icon="sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg data-theme-icon="moon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3c0 4.97 4.03 9 9 9 .27 0 .53-.01.79-.21z" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-teal-900 dark:bg-stone-900 text-cream-200 dark:text-stone-300 mt-16">
      <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col sm:flex-row gap-4 justify-between items-start text-sm">
        <div>
          <p class="font-arabic text-gold-400 text-lg mb-1">مكتبة الفتاوى</p>
          <p class="text-cream-200/70 dark:text-stone-400">Fatawa Library: translations of Islamic legal rulings from senior scholars.</p>
        </div>
        <div class="text-cream-200/50 dark:text-stone-500 text-xs mt-2 sm:mt-0 sm:text-right">
          <p>Translations are provided for educational purposes.</p>
          <p class="mt-1">Always refer to a qualified scholar for personal guidance.</p>
          <p class="mt-1">2026 Fatawa Library</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const toggle = document.getElementById('theme-toggle');
        const sun = document.querySelector('[data-theme-icon="sun"]');
        const moon = document.querySelector('[data-theme-icon="moon"]');

        if (!(toggle instanceof HTMLButtonElement) || !sun || !moon) return;

        const syncIcons = () => {
          const isDark = document.documentElement.classList.contains('dark');
          sun.classList.toggle('hidden', isDark);
          moon.classList.toggle('hidden', !isDark);
        };

        syncIcons();

        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          syncIcons();
        });
      })();
    </script>

  </body>
</html>
