---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FilterBar from '../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const allFatwas = (await getCollection('fatwas')).sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime());
const scholarCount = (await getCollection('scholars')).length;
const fatwaCount = allFatwas.length;
const categorySet = new Set<string>();
allFatwas.forEach(f => f.data.categories.forEach((c: string) => categorySet.add(c)));
const categoryCount = categorySet.size;
const allCategories = [...categorySet].sort();

const activeScholar = Astro.url.searchParams.get('scholar') || undefined;
const activeCategory = Astro.url.searchParams.get('category') || undefined;

const allScholars = await getCollection('scholars');
const scholarNameMap = new Map(allScholars.map(s => [s.id, s.data.name]));
---

<Layout title="Home">
  <Hero
    rulingsCount={fatwaCount}
    scholarsCount={scholarCount}
    categoriesCount={categoryCount}
    eyebrow="Islamic Legal Rulings"
    title="A Scholarly Archive of Verified Fatwas"
    subtitle="Authentic religious rulings from trusted scholars across traditions — carefully collected, categorised, and made readable."
  />

  <FilterBar
    allCategories={allCategories}
    activeScholar={activeScholar}
    activeCategory={activeCategory}
  />

  <div id="fatwa-grid">
    <ul class="fatwa-registry">
      {allFatwas.map(fatwa => {
        const fullName = scholarNameMap.get(fatwa.data.scholar) || fatwa.data.scholar;
        const shortName = fullName.split(' ').pop();
        return (
          <li
            class="fatwa-registry-item"
            data-scholar={fatwa.data.scholar}
            data-categories={fatwa.data.categories.map((c: string) => c.toLowerCase().replace(/\s+/g, '-')).join(',')}
            onclick={`window.location.href='/fatwa/${fatwa.id}'`}
            style="cursor: pointer;"
          >
            <span class="fatwa-registry-date">{fatwa.data.date_added.toLocaleDateString()}</span>
            <div class="fatwa-registry-title-wrap">
              <span class="fatwa-registry-title">{fatwa.data.title || `Fatwa #${fatwa.id}`}</span>
              {fatwa.data.categories.length > 0 && (
                <span class="fl-cat-pill">{fatwa.data.categories[0]}</span>
              )}
            </div>
            <span class="fatwa-registry-scholar">{shortName}</span>
          </li>
        );
      })}
    </ul>
  </div>

  <p id="empty-state" class="hidden text-center py-12 text-[var(--text-muted)]">No fatwas match this filter.</p>
</Layout>

<script>
  function applyFilters() {
    const params = new URLSearchParams(window.location.search);
    const scholar = params.get('scholar');
    const category = params.get('category');

    const items = document.querySelectorAll<HTMLLIElement>('.fatwa-registry-item');
    let visible = 0;
    items.forEach(item => {
      const matchesScholar = !scholar || item.dataset.scholar === scholar;
      const matchesCategory = !category || (item.dataset.categories ?? '').split(',').includes(category);
      const show = matchesScholar && matchesCategory;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const empty = document.getElementById('empty-state');
    if (empty) empty.classList.toggle('hidden', visible > 0);
  }
  applyFilters();
</script>