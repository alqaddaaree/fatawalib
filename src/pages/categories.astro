---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allFatwas = await getCollection('fatwas');
const categoryMap = new Map<string, number>();
allFatwas.forEach(f => {
  f.data.categories.forEach((cat: string) => {
    categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
  });
});
const allCategories = [...categoryMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<Layout title="Categories">
  <div class="categories-header">
    <h1>Categories</h1>
    <p class="categories-subtitle">Browse fatwas by category</p>
  </div>

  <!-- Search input -->
  <div class="categories-search">
    <input
      type="text"
      id="category-search"
      placeholder="Filter categories…"
      class="categories-search-input"
    />
  </div>

  <div id="categories-grid" class="categories-grid">
    {allCategories.map(([name, count]) => (
      <a
        href={`/category/${name.toLowerCase().replace(/\s+/g, '-')}`}
        class="category-card"
        data-category-name={name.toLowerCase()}
      >
        <span class="category-name">{name}</span>
        <span class="category-count">{count}</span>
      </a>
    ))}
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('category-search') as HTMLInputElement;
  const grid = document.getElementById('categories-grid');
  const cards = grid?.querySelectorAll('.category-card');

  if (searchInput && cards) {
    searchInput.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase().trim();
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const name = el.getAttribute('data-category-name') || '';
        if (term === '' || name.includes(term)) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  }
</script>

<style>
  .categories-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-default);
    margin-bottom: 1rem;
  }
  .categories-header h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .categories-subtitle {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-muted);
  }
  .categories-search {
    padding: 0 2rem 1rem;
  }
  .categories-search-input {
    width: 100%;
    max-width: 320px;
    padding: 8px 1rem;
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: 99px;
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .categories-search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-light);
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    padding: 0 2rem 2rem;
  }
  .category-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 0.5px solid var(--border-default);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }
  .category-card:hover {
    background: var(--bg-hover);
    border-color: var(--accent-light);
  }
  .category-name {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-primary);
  }
  .category-count {
    font-family: var(--font-ui);
    font-size: 11px;
    background: var(--bg-pill);
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 99px;
  }
</style>