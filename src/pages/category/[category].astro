---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FatwaCard from '../../components/FatwaCard.astro';

export async function getStaticPaths() {
  const allFatwas = await getCollection('fatwas');
  const slugMap = new Map<string, { name: string; fatwas: typeof allFatwas }>();
  allFatwas.forEach(fatwa => {
    fatwa.data.categories.forEach((cat: string) => {
      const slug = cat.toLowerCase().replace(/\s+/g, '-');
      if (!slugMap.has(slug)) slugMap.set(slug, { name: cat, fatwas: [] });
      slugMap.get(slug)!.fatwas.push(fatwa);
    });
  });
  return [...slugMap.entries()].map(([slug, { name, fatwas }]) => ({
    params: { category: slug },
    props: {
      categoryName: name,
      fatwas: fatwas.sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime()),
    },
  }));
}

const { categoryName, fatwas } = Astro.props;

// Fetch scholar names for each fatwa (we need to map scholar id to name)
const allScholars = await getCollection('scholars');
const scholarMap = new Map(allScholars.map(s => [s.id, s.data.name]));
---

<Layout title={`${categoryName} – Fatwas`}>
  <div class="category-header">
    <h1>{categoryName}</h1>
    <p>{fatwas.length} fatwa{fatwas.length !== 1 ? 's' : ''}</p>
  </div>

  <div class="cards-grid">
    {fatwas.map(f => (
      <FatwaCard
        id={f.id}
        title={f.data.title}
        categories={f.data.categories}
        scholarName={scholarMap.get(f.data.scholar) || f.data.scholar}
        date={f.data.date_added}
      />
    ))}
  </div>
</Layout>

<style>
  .category-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid var(--border-default);
    margin-bottom: 1rem;
  }
  .category-header h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .category-header p {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-muted);
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    padding: 0 2rem 2rem;
  }
</style>