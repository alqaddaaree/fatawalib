---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allScholars = await getCollection('scholars');
const allFatwas = await getCollection('fatwas');

const counts: Record<string, number> = {};
for (const scholar of allScholars) {
  counts[scholar.id] = 0;
}
for (const fatwa of allFatwas) {
  counts[fatwa.data.scholar]++;
}
---

<Layout title="Scholars">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="font-sans text-3xl font-medium mb-2 text-primary">Scholars</h1>
    <p class="text-sm mb-8 text-secondary">Browse fatwas by scholar. Click a card to see all their rulings.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {allScholars.map((scholar) => {
        const scholarId = scholar.id;
        const s = scholar.data;
        return (
          <a
            href={`/scholar/${scholarId}`}
            class="group rounded-sm p-6 flex flex-col gap-3 transition-all bg-card border border-border text-primary hover:-translate-y-0.5 hover:shadow-md"
          >
            <div class="flex items-center justify-between">
              <div>
                <p class="font-arabic text-2xl leading-none mb-1 text-accent-hover">{s.arabicName}</p>
                <h2 class="font-sans text-lg font-medium transition-colors text-primary">{s.name}</h2>
                <p class="text-xs font-sans text-muted">{s.lifespan}</p>
              </div>
              <span class="flex items-center justify-center shrink-0 w-12 h-12 text-sm font-sans font-semibold rounded-sm bg-accent text-page">
                {counts[scholarId]}
              </span>
            </div>
            <p class="text-sm line-clamp-3 text-secondary">{s.bio}</p>
            <span class="text-xs font-sans font-medium transition-colors text-accent">
              View {counts[scholarId]} fatwa{counts[scholarId] !== 1 ? 's' : ''} →
            </span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>