---
import type { CollectionEntry } from 'astro:content';
import { getScholar } from '../data/scholars';

export interface Props {
  fatwa: CollectionEntry<'fatwas'>;
}

const { fatwa } = Astro.props;
const { id, scholar, categories, date_added, translator } = fatwa.data;
const scholarInfo = getScholar(scholar);

function stripMarkdown(input: string): string {
  return input
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/!\[[^\]]*\]\([^\)]*\)/g, ' ')
    .replace(/\[([^\]]+)\]\([^\)]*\)/g, '$1')
    .replace(/[>*_~#-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function truncateText(input: string, max = 100): string {
  if (input.length <= max) return input;
  return `${input.slice(0, max).trimEnd()}...`;
}

function extractQuestion(body: string): string | null {
  const match = body.match(/##\s*Question\s*([\s\S]*?)(?:\n##\s*Answer\b|\n##\s*[^\n]+|$)/i);
  if (!match?.[1]) return null;
  const plain = stripMarkdown(match[1]);
  return plain ? truncateText(plain, 100) : null;
}

const cardTitle = extractQuestion(fatwa.body) ?? `Fatwa #${id}`;
---

<article class="bg-white dark:bg-stone-900 border border-sand-200 dark:border-stone-700 rounded-xl p-5 hover:shadow-md hover:border-teal-800/30 dark:hover:border-gold-500/40 transition-all group">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex-1 min-w-0">
      <!-- Categories -->
      <div class="flex flex-wrap gap-1.5 mb-2">
        {categories.slice(0, 3).map((cat) => (
          <a
            href={`/category/${encodeURIComponent(cat.toLowerCase().replace(/\s+/g, '-'))}`}
            class="text-xs font-sans font-medium bg-cream-100 dark:bg-stone-800 text-teal-800 dark:text-stone-200 border border-sand-200 dark:border-stone-600 rounded-full px-2.5 py-0.5 hover:bg-teal-900 hover:text-white hover:border-teal-900 transition-colors"
          >
            {cat}
          </a>
        ))}
      </div>

      <!-- Question title -->
      <a href={`/fatwa/${id}`} class="block">
        <h2 class="font-serif text-lg text-teal-900 dark:text-cream-100 group-hover:text-gold-600 transition-colors leading-snug line-clamp-2">
          {cardTitle}
        </h2>
      </a>
    </div>

    <!-- Scholar badge -->
    <span class="shrink-0 text-xs font-sans font-medium bg-teal-900 dark:bg-stone-800 text-cream-100 rounded-lg px-2.5 py-1 whitespace-nowrap">
      {scholarInfo.name.replace('Shaykh ', '')}
    </span>
  </div>

  <!-- Meta -->
  <div class="flex items-center gap-3 text-xs text-stone-500 dark:text-stone-400 font-sans mt-3 pt-3 border-t border-sand-100 dark:border-stone-700">
    <span>Trans. {translator}</span>
    <span class="text-sand-300 dark:text-stone-600">•</span>
    <time datetime={date_added.toISOString()}>
      {date_added.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
    <a href={`/fatwa/${id}`} class="ml-auto text-teal-800 dark:text-gold-400 hover:text-gold-600 font-medium transition-colors">
      Read →
    </a>
  </div>
</article>
