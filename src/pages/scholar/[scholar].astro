---
import Layout from '../../layouts/Layout.astro';
import FatwaCard from '../../components/FatwaCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allScholars = await getCollection('scholars');
  const allFatwas = await getCollection('fatwas');
  return allScholars.map(scholar => ({
    params: { scholar: scholar.id },
    props: {
      scholar: scholar.data,
      fatwas: allFatwas
        .filter(f => f.data.scholar === scholar.id)
        .sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime()),
    },
  }));
}

const { scholar, fatwas } = Astro.props;
---

<Layout title={`${scholar.name} – Fatwas`}>
  <div class="scholar-header">
    <h1>{scholar.name}</h1>
    {scholar.arabicName && <p class="scholar-arabic">{scholar.arabicName}</p>}
    <p class="scholar-bio">{scholar.bio}</p>
  </div>

  <div class="cards-grid">
    {fatwas.map(f => (
      <FatwaCard
        id={f.id}
        title={f.data.title}
        categories={f.data.categories}
        scholarName={scholar.name}
        date={f.data.date_added}
      />
    ))}
  </div>
</Layout>

<style>
  .scholar-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid var(--border-default);
    margin-bottom: 1rem;
  }
  .scholar-header h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .scholar-arabic {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .scholar-bio {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--text-secondary);
    max-width: 65ch;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    padding: 0 2rem 2rem;
  }
</style>