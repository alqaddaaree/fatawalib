---
const { id, title, question, answer } = Astro.props as { id: string; title: string; question?: string; answer?: string };
const pageURL = Astro.site ? new URL(`/fatwa/${id}`, Astro.site).toString() : `/fatwa/${id}`;
const shareText = `${title}\n\n${question || ''}\n\n${answer ? answer.slice(0, 200) + (answer.length > 200 ? '…' : '') : ''}`;
const fullMessage = encodeURIComponent(`${title}\n\nRead more: ${pageURL}`);
---

<div class="relative" x-data="{ open: false }">
  <button
    @click="open = !open"
    class="text-xs px-3 py-1 rounded-sm font-medium transition-colors bg-accent text-page hover:bg-accent-hover"
    aria-label="Share this fatwa"
  >
    Share
  </button>

  <div
    x-show="open"
    @click.away="open = false"
    x-cloak
    class="absolute left-0 mt-2 w-48 rounded-sm shadow-lg bg-card border border-border z-50"
  >
    <div class="py-1">
      <a
        href={`https://wa.me/?text=${fullMessage}`}
        target="_blank"
        rel="noopener noreferrer"
        class="block px-4 py-2 text-xs text-primary hover:bg-tag transition-colors"
      >
        WhatsApp
      </a>
      <a
        href={`https://t.me/share/url?url=${encodeURIComponent(pageURL)}&text=${encodeURIComponent(shareText)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="block px-4 py-2 text-xs text-primary hover:bg-tag transition-colors"
      >
        Telegram
      </a>
      <a
        href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`${shareText}\n\n${pageURL}`)}`}
        class="block px-4 py-2 text-xs text-primary hover:bg-tag transition-colors"
      >
        Email
      </a>
      <button
        @click="navigator.clipboard.writeText($el.getAttribute('data-url')); alert('Link copied to clipboard'); open = false"
        data-url={pageURL}
        class="block w-full text-left px-4 py-2 text-xs text-primary hover:bg-tag transition-colors"
      >
        Copy link
      </button>
      <button
        @click="navigator.clipboard.writeText($el.getAttribute('data-text')); alert('Fatwa text copied to clipboard'); open = false"
        data-text={shareText}
        class="block w-full text-left px-4 py-2 text-xs text-primary hover:bg-tag transition-colors"
      >
        Copy fatwa
      </button>
    </div>
  </div>
</div>

<style>
  [x-cloak] { display: none !important; }
</style>