---
interface Props {
  scholars: { slug: string; name: string }[];
  allCategories: string[];
}
const { scholars, allCategories } = Astro.props;
---

<div id="search-root" class="search-page">
  <div class="search-header">
    <h1>Search fatwas</h1>
    <p class="search-subtitle">Search by keyword, scholar, or category across all translated fatwas.</p>
  </div>

  <!-- Search input -->
  <div class="search-input-wrapper">
    <input
      id="search-input"
      type="search"
      placeholder="e.g., prayer, fasting, zakah..."
      autocomplete="off"
      class="search-input"
    />
  </div>

  <!-- Filter pills -->
  <div class="filter-pills">
    <div class="filter-section">
      <span class="filter-label">Scholar</span>
      <div class="filter-buttons">
        <button class="filter-pill" data-filter-type="scholar" data-filter-value="">All</button>
        {scholars.map(s => (
          <button class="filter-pill" data-filter-type="scholar" data-filter-value={s.slug}>
            {s.name.replace('Shaykh ', '')}
          </button>
        ))}
      </div>
    </div>
    <div class="filter-section">
      <span class="filter-label">Category</span>
      <div class="filter-buttons">
        <button class="filter-pill" data-filter-type="category" data-filter-value="">All</button>
        {allCategories.map(cat => (
          <button class="filter-pill" data-filter-type="category" data-filter-value={cat.toLowerCase().replace(/\s+/g, '-')}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Status / results count -->
  <p id="search-status" class="search-status"></p>

  <!-- Results -->
  <div id="search-results" class="search-results"></div>

  <!-- No results -->
  <div id="no-results" class="search-no-results hidden">
    <p>No results found</p>
    <p class="text-sm">Try different keywords or browse by <a href="/categories" class="search-cat-link">category</a>.</p>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  interface FatwaEntry {
    id: string;
    title: string;
    scholar: string;
    scholarName: string;
    categories: string[];
    translator: string;
    date_added: string;
    body: string;
  }

  let fuse: Fuse<FatwaEntry> | null = null;
  let allData: FatwaEntry[] = [];

  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsDiv = document.getElementById('search-results') as HTMLDivElement;
  const statusDiv = document.getElementById('search-status') as HTMLParagraphElement;
  const noResultsDiv = document.getElementById('no-results') as HTMLDivElement;
  const filterPills = document.querySelectorAll('.filter-pill');

  // Helper to update URL params without reload
  function updateUrlParams(params: Record<string, string>) {
    const url = new URL(window.location.href);
    for (const [key, value] of Object.entries(params)) {
      if (value) url.searchParams.set(key, value);
      else url.searchParams.delete(key);
    }
    window.history.pushState({}, '', url.toString());
  }

  function getUrlParams() {
    const params = new URLSearchParams(window.location.search);
    return {
      q: params.get('q') || '',
      scholar: params.get('scholar') || '',
      category: params.get('category') || '',
    };
  }

  function setActiveFilters() {
    const { scholar, category } = getUrlParams();
    filterPills.forEach(btn => {
      const type = btn.getAttribute('data-filter-type');
      const value = btn.getAttribute('data-filter-value');
      if (type === 'scholar') {
        if ((value === '' && !scholar) || (value === scholar)) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      } else if (type === 'category') {
        if ((value === '' && !category) || (value === category)) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      }
    });
  }

  function performSearch() {
    if (!fuse) return;
    const { q, scholar, category } = getUrlParams();
    let items = allData;

    // Fuzzy search only if query present
    if (q.trim()) {
      const hits = fuse.search(q, { limit: 100 });
      items = hits.map(h => h.item);
    }

    // Apply scholar filter
    if (scholar) {
      items = items.filter(item => item.scholar === scholar);
    }
    // Apply category filter
    if (category) {
      items = items.filter(item => item.categories.map(c => c.toLowerCase().replace(/\s+/g, '-')).includes(category));
    }

    // Update UI
    statusDiv.textContent = q ? `${items.length} result${items.length !== 1 ? 's' : ''} for "${q}"` : `${items.length} fatwa${items.length !== 1 ? 's' : ''}`;
    if (items.length === 0) {
      resultsDiv.innerHTML = '';
      noResultsDiv.classList.remove('hidden');
    } else {
      noResultsDiv.classList.add('hidden');
      resultsDiv.innerHTML = `<ul class="fatwa-registry">${items.map(renderRegistryRow).join('')}</ul>`;
    }
  }

  function renderRegistryRow(entry: FatwaEntry): string {
    const date = new Date(entry.date_added);
    const formattedDate = date.toLocaleDateString();
    const title = entry.title || `Fatwa #${entry.id}`;
    const shortName = entry.scholarName.split(' ').pop() || entry.scholar;
    const topCategory = entry.categories?.[0] || '';
    return `
      <li class="fatwa-registry-item" onclick="window.location.href='/fatwa/${entry.id}'" style="cursor: pointer;">
        <span class="fatwa-registry-date">${formattedDate}</span>
        <div class="fatwa-registry-title-wrap">
          <span class="fatwa-registry-title">${escapeHtml(title)}</span>
          ${topCategory ? `<span class="fl-cat-pill">${escapeHtml(topCategory)}</span>` : ''}
        </div>
        <span class="fatwa-registry-scholar">${escapeHtml(shortName)}</span>
      </li>
    `;
  }

  function escapeHtml(str: string): string {
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // Load index
  fetch('/search-index.json')
    .then(res => res.json())
    .then((data: FatwaEntry[]) => {
      allData = data;
      fuse = new Fuse(data, {
        keys: [
          { name: 'title', weight: 0.4 },
          { name: 'body', weight: 1.0 },
          { name: 'categories', weight: 0.2 },
          { name: 'scholarName', weight: 0.1 },
        ],
        threshold: 0.3,
        ignoreLocation: true,
        minMatchCharLength: 3,
      });
      setActiveFilters();
      performSearch();
    })
    .catch(() => {
      statusDiv.textContent = 'Search index unavailable.';
    });

  // Input handler
  let debounceTimer: ReturnType<typeof setTimeout>;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const q = input.value.trim();
      updateUrlParams({ q });
      performSearch();
    }, 220);
  });

  // Filter pill clicks
  filterPills.forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.getAttribute('data-filter-type');
      const value = btn.getAttribute('data-filter-value');
      const currentParams = getUrlParams();
      if (type === 'scholar') {
        updateUrlParams({ ...currentParams, scholar: value || '', q: currentParams.q });
      } else if (type === 'category') {
        updateUrlParams({ ...currentParams, category: value || '', q: currentParams.q });
      }
      setActiveFilters();
      performSearch();
    });
  });

  // Sync input value with URL on load
  const { q } = getUrlParams();
  if (q) input.value = q;

  // Auto-focus
  input.focus();
</script>

<style>
  .search-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
  }
  .search-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .search-header h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .search-subtitle {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-muted);
  }
  .search-input-wrapper {
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .search-input {
    width: 100%;
    padding: 10px 1.25rem;
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: 99px;
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-light);
  }
  .filter-pills {
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--border-default);
    padding-top: 1.5rem;
  }
  .filter-section {
    margin-bottom: 1rem;
  }
  .filter-label {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    width: 70px;
    vertical-align: top;
    padding-top: 0.25rem;
  }
  .filter-buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .filter-pill {
    font-family: var(--font-ui);
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 99px;
    border: 1px solid var(--border-default);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition), color var(--transition);
  }
  .filter-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-pill);
  }
  .filter-pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .search-status {
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .search-results {
    margin-top: 1rem;
  }
  .search-no-results {
    text-align: center;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--text-secondary);
    padding: 3rem;
    background: var(--bg-card);
    border-radius: var(--radius-card);
    border: 0.5px solid var(--border-default);
  }
  .search-no-results p:first-child {
    margin-bottom: 0.5rem;
  }
  .search-cat-link {
    color: var(--accent);
    text-decoration: none;
  }
  .search-cat-link:hover {
    text-decoration: underline;
  }
</style>