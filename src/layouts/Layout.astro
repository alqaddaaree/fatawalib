---
export interface Props {
  title:       string;
  description?: string;
}

const { title, description = 'Fatawa Library is a curated archive of Islamic fatwas from senior scholars.' } = Astro.props;
const siteOrigin = Astro.site ?? new URL('https://fatawalib.com');
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL('/og-image-placeholder.jpg', siteOrigin);
---

<!doctype html>
<html lang="en" dir="auto">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImage.toString()} />

    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Source+Sans+3:wght@300;400;500;600&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <title>{title} — Fatawa Library</title>
    <style>@import url('/src/styles/global.css');</style>
    <slot name="head" />
  </head>

  <body class="min-h-screen flex flex-col" style="background-color: var(--bg-page); color: var(--text-primary);">

    <!-- Top bar -->
    <header style="background-color: var(--accent); color: var(--bg-page);">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4 flex-wrap">
        <a href="/" class="flex flex-col leading-tight group">
          <span class="font-arabic text-2xl transition-colors" style="color: var(--accent-hover);">مكتبة الفتاوى</span>
          <span class="font-serif text-base tracking-wide transition-colors" style="color: var(--bg-page);">Fatawa Library</span>
        </a>
        <nav class="flex items-center gap-3 sm:gap-4 text-sm font-sans font-medium">
          <a href="/" style="color: var(--bg-page);" class="opacity-70 hover:opacity-100 transition-opacity">Home</a>
          <a href="/scholars" style="color: var(--bg-page);" class="opacity-70 hover:opacity-100 transition-opacity">Scholars</a>
          <a href="/categories" style="color: var(--bg-page);" class="opacity-70 hover:opacity-100 transition-opacity">Categories</a>
          <a href="/about" style="color: var(--bg-page);" class="opacity-70 hover:opacity-100 transition-opacity">About</a>

          <form action="/search" method="get" class="hidden md:flex items-center gap-1">
            <input
              type="search"
              name="q"
              placeholder="Search fatwas"
              class="w-44 lg:w-52 px-2.5 py-1.5 text-xs focus:outline-none"
              style="background-color: var(--bg-page); color: var(--text-primary); border: 1px solid var(--border-default);"
            />
            <button
              type="submit"
              class="px-3 py-1.5 text-xs text-white transition-colors font-medium"
              style="background-color: var(--accent); border: 1px solid var(--accent);"
            >
              Search
            </button>
          </form>

          <a href="/search" class="md:hidden opacity-70 hover:opacity-100 transition-opacity" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="7" />
              <path d="m20 20-3.5-3.5" />
            </svg>
          </a>

          <button
            id="theme-toggle"
            type="button"
            class="inline-flex items-center justify-center p-1.5 transition-opacity opacity-70 hover:opacity-100"
            style="border: 1px solid rgba(255, 255, 255, 0.3);"
            aria-label="Toggle dark mode"
          >
            <svg data-theme-icon="sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            <svg data-theme-icon="moon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3c0 4.97 4.03 9 9 9 .27 0 .53-.01.79-.21z" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background-color: var(--accent); color: var(--bg-page);">
      <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col sm:flex-row gap-4 justify-between items-start text-sm">
        <div>
          <p class="font-arabic text-lg mb-1" style="color: var(--accent-hover);">مكتبة الفتاوى</p>
          <p style="color: rgba(245, 241, 234, 0.7);">Fatawa Library: translations of Islamic legal rulings from senior scholars.</p>
        </div>
        <div style="color: rgba(245, 241, 234, 0.5);" class="text-xs mt-2 sm:mt-0 sm:text-right">
          <p>Translations are provided for educational purposes.</p>
          <p class="mt-1">Always refer to a qualified scholar for personal guidance.</p>
          <p class="mt-1">2026 Fatawa Library</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const toggle = document.getElementById('theme-toggle');
        const sun = document.querySelector('[data-theme-icon="sun"]');
        const moon = document.querySelector('[data-theme-icon="moon"]');

        if (!(toggle instanceof HTMLButtonElement) || !sun || !moon) return;

        const syncIcons = () => {
          const isDark = document.documentElement.classList.contains('dark');
          sun.classList.toggle('hidden', isDark);
          moon.classList.toggle('hidden', !isDark);
        };

        syncIcons();

        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          syncIcons();
        });
      })();
    </script>

  </body>
</html>
