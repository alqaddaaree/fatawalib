---
import { formatHijriDate, formatGregorian } from '../utils/hijri';

interface FatwaHeaderProps {
  fatwa: {
    data: {
      id: string;
      title?: string;
      categories: string[];
      source_url?: string;
      translator?: string;
      reviewer?: string;
      date_issued?: string;
      date_issued_gregorian?: string;
      date_added: Date;
      audience?: string;
      tags?: string[];
    };
  };
  scholarInfo: {
    name: string;
    arabicName?: string;
  };
}

const { fatwa, scholarInfo } = Astro.props as FatwaHeaderProps;
const { id, title, categories, source_url, translator, reviewer, date_issued, date_issued_gregorian, date_added, audience, tags } = fatwa.data;
---

<header class="fatwa-header-block">
  <div class="fatwa-header-watermark">فتوى</div>
  <p class="fatwa-header-id">Fatwa #{id}</p>
  <h1 class="fatwa-header-title">
    {title || `${scholarInfo.name}`}
    {scholarInfo.arabicName && (
      <span class="fatwa-header-arabic">{scholarInfo.arabicName}</span>
    )}
  </h1>

  <div class="fatwa-header-categories">
    {categories.map((cat: string) => (
      <a
        href={`/category/${cat.toLowerCase().replace(/\s+/g, '-')}`}
        class="fatwa-header-cat-pill"
      >
        {cat}
      </a>
    ))}
  </div>

  <dl class="fatwa-header-meta">
    <div>
      <dt>Audience</dt>
      <dd>{audience || 'general'}</dd>
    </div>
    <div>
      <dt>Translator</dt>
      <dd>{translator || '—'}</dd>
    </div>
    {reviewer && (
      <div>
        <dt>Reviewer</dt>
        <dd>{reviewer}</dd>
      </div>
    )}
    <div>
      <dt>Date Issued (Hijri)</dt>
      <dd>{formatHijriDate(date_issued)}</dd>
    </div>
    <div>
      <dt>Date Issued (Gregorian)</dt>
      <dd>{formatGregorian(date_issued_gregorian || date_added)}</dd>
    </div>
  </dl>

  {tags && tags.length > 0 && (
    <p class="fatwa-header-tags">Tags: {tags.join(', ')}</p>
  )}
</header>

<style>
  .fatwa-header-block {
    position: relative;
    overflow: hidden;
    background: var(--bg-page);
    padding: 2rem 2rem 1.5rem;
    border-bottom: 2px solid var(--accent-light);
    margin-bottom: 2rem;
  }
  .fatwa-header-watermark {
    position: absolute;
    right: 1rem;
    top: 0.5rem;
    font-family: var(--font-serif);
    font-size: 6rem;
    line-height: 1;
    color: var(--accent-light);
    opacity: 0.3;
    pointer-events: none;
    user-select: none;
  }
  .fatwa-header-id {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .fatwa-header-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.45;
    color: var(--text-primary);
    max-width: 65ch;
    margin-bottom: 1rem;
  }
  .fatwa-header-arabic {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }
  .fatwa-header-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .fatwa-header-cat-pill {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 99px;
    background: var(--bg-pill);
    color: var(--accent);
    border: 1px solid var(--accent-light);
    text-decoration: none;
    transition: background var(--transition), border-color var(--transition);
  }
  .fatwa-header-cat-pill:hover {
    background: var(--accent-light);
    border-color: var(--accent);
  }
  .fatwa-header-meta {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--border-default);
  }
  .fatwa-header-meta dt {
    font-family: var(--font-ui);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }
  .fatwa-header-meta dd {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
  }
  .fatwa-header-tags {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 1rem;
  }
</style>