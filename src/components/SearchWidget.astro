---
// SearchWidget.astro — loaded only on the /search page
---

<div id="search-root" class="max-w-3xl mx-auto px-4 py-10">
  <div class="mb-8">
    <h1 class="font-serif text-3xl mb-2" style="color: var(--text-primary);">Search Fatāwā</h1>
    <p style="color: var(--text-secondary);" class="text-sm">Search by keyword, scholar, or category across all translated fatwas.</p>
  </div>

  <!-- Search input -->
  <div class="relative mb-6">
    <span class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" style="color: var(--text-muted);">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
    </span>
    <input
      id="search-input"
      type="search"
      placeholder="Search fatwas…"
      autocomplete="off"
      class="w-full pl-10 pr-4 py-3 text-base font-sans focus:outline-none rounded-sm"
      style="background-color: var(--bg-card); color: var(--text-primary); border: 1px solid var(--border-default);"
    />
  </div>

  <!-- Status / results count -->
  <p id="search-status" class="text-xs mb-4 font-sans" style="color: var(--text-muted);"></p>

  <!-- Results -->
  <div id="search-results" class="space-y-3"></div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-12" style="color: var(--text-secondary);">
    <p class="font-serif text-xl mb-2">No results found</p>
    <p class="text-sm">Try different keywords or browse by <a href="/categories" class="underline transition-colors" style="color: var(--accent);">category</a>.</p>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  interface FatwaEntry {
    id: string;
    scholar: string;
    scholarName: string;
    categories: string[];
    translator: string;
    date_added: string;
    body: string;
  }

  const input     = document.getElementById('search-input') as HTMLInputElement;
  const results   = document.getElementById('search-results') as HTMLDivElement;
  const status    = document.getElementById('search-status') as HTMLParagraphElement;
  const noResults = document.getElementById('no-results') as HTMLDivElement;

  let fuse: Fuse<FatwaEntry> | null = null;

  // Load index
  fetch('/search-index.json')
    .then((r) => r.json())
    .then((data: FatwaEntry[]) => {
      fuse = new Fuse(data, {
        keys: [
          { name: 'id',          weight: 0.1 },
          { name: 'scholar',     weight: 0.2 },
          { name: 'scholarName', weight: 0.2 },
          { name: 'categories',  weight: 0.3 },
          { name: 'body',        weight: 1.0 },
          { name: 'translator',  weight: 0.1 },
        ],
        threshold:       0.35,
        includeMatches:  true,
        minMatchCharLength: 3,
        ignoreLocation:  true,
      });
      status.textContent = `${data.length} fatwas indexed`;
    })
    .catch(() => {
      status.textContent = 'Search index unavailable.';
    });

  function renderCard(entry: FatwaEntry): string {
    const cats = entry.categories
      .map((c) => `<span class="inline-block text-xs rounded-sm px-2.5 py-0.5 font-sans font-medium uppercase" style="background-color: var(--bg-tag); color: var(--accent); border: 1px solid var(--border-emphasis); letter-spacing: 0.07em;">${c}</span>`)
      .join('');
    return `
      <article class="rounded-sm p-5 transition-all" style="background-color: var(--bg-card); border: 1px solid var(--border-default); color: var(--text-primary);">
        <div class="flex items-start justify-between gap-3 mb-2">
          <div>
            <div class="flex flex-wrap gap-1.5 mb-2">${cats}</div>
            <a href="/fatwa/${entry.id}" class="font-serif text-lg italic" style="color: var(--text-primary);">
              Fatwa #${entry.id}
            </a>
          </div>
          <span class="shrink-0 text-xs font-sans font-medium rounded-sm px-2.5 py-1" style="background-color: var(--accent); color: var(--bg-page);">${entry.scholarName.replace('Shaykh ', '')}</span>
        </div>
        <p class="text-sm line-clamp-2 mt-2" style="color: var(--text-secondary);">${entry.body ? entry.body.slice(0, 200) : ''}…</p>
        <div class="mt-3 pt-3 border-none flex items-center gap-3 text-xs font-sans" style="border-top: 1px solid var(--border-default); color: var(--text-muted);">
          <span>Trans. ${entry.translator}</span>
          <span class="ml-auto font-medium">
            <a href="/fatwa/${entry.id}" style="color: var(--accent);">Read →</a>
          </span>
        </div>
      </article>
    `;
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const query = input.value.trim();

      if (!query || !fuse) {
        results.innerHTML = '';
        noResults.classList.add('hidden');
        status.textContent = fuse ? `${(fuse as any)._docs.length} fatwas indexed` : '';
        return;
      }

      const hits = fuse.search(query, { limit: 20 });
      status.textContent = `${hits.length} result${hits.length !== 1 ? 's' : ''} for "${query}"`;

      if (hits.length === 0) {
        results.innerHTML = '';
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
        results.innerHTML = hits.map((h) => renderCard(h.item)).join('');
      }
    }, 220);
  });

  // Auto-focus
  input.focus();
</script>
