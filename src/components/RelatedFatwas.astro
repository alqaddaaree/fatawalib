---
interface RelatedItem {
  fatwa: any;
  scholar: { name: string };
  question: string;
}

const { items } = Astro.props as { items: RelatedItem[] };
---

{items && items.length > 0 ? (
  <section class="mt-10">
    <h2 class="font-serif text-xl text-teal-900 dark:text-gold-400 mb-4">Related Fatāwā</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {items.map((item) => (
        <a href={`/fatwa/${item.fatwa.id}`} class="block rounded-xl border border-sand-200 dark:border-stone-700 bg-white dark:bg-stone-900 p-4 hover:border-teal-800/40 dark:hover:border-gold-500/40 transition-colors">
          <p class="text-xs text-teal-800 dark:text-gold-400 font-medium mb-1">{item.scholar.name.replace('Shaykh ', '')}</p>
          <p class="font-serif text-sm text-stone-800 dark:text-stone-100 leading-snug line-clamp-3">{item.question}</p>
          <p class="text-xs text-stone-500 dark:text-stone-400 mt-2">{item.fatwa.date_added.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
        </a>
      ))}
    </div>
  </section>
) : null}
