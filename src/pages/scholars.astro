---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const scholars = await getCollection('scholars');
const fatwas = await getCollection('fatwas');
const counts = Object.fromEntries(scholars.map(s => [s.id, fatwas.filter(f => f.data.scholar === s.id).length]));
---

<Layout title="Scholars">
  <div class="scholars-header">
    <h1>Scholars</h1>
    <p>Browse fatwas by scholar</p>
  </div>

  <div class="scholars-grid">
    {scholars.map(s => (
      <a href={`/scholar/${s.id}`} class="scholar-card">
        <div>
          <div class="scholar-name">{s.data.name}</div>
          <div class="scholar-bio">{s.data.bio.slice(0, 80)}…</div>
        </div>
        <div class="scholar-count">{counts[s.id]} fatwa{counts[s.id] !== 1 ? 's' : ''}</div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .scholars-header {
    padding: 2rem 2rem 1rem;
    border-bottom: 1px solid var(--border-default);
    margin-bottom: 1rem;
  }
  .scholars-header h1 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .scholars-header p {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-muted);
  }
  .scholars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    padding: 0 2rem 2rem;
  }
  .scholar-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-card);
    border: 0.5px solid var(--border-default);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: background var(--transition), border-color var(--transition);
  }
  .scholar-card:hover {
    background: var(--bg-hover);
    border-color: var(--accent-light);
  }
  .scholar-name {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .scholar-bio {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--text-muted);
    line-height: 1.4;
  }
  .scholar-count {
    font-family: var(--font-ui);
    font-size: 11px;
    background: var(--bg-pill);
    color: var(--accent);
    padding: 4px 10px;
    border-radius: 99px;
    white-space: nowrap;
  }
</style>