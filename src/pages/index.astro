---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const allFatwas = (await getCollection('fatwas')).sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime());
const scholarCount = (await getCollection('scholars')).length;
const fatwaCount = allFatwas.length;
const categorySet = new Set<string>();
allFatwas.forEach(f => f.data.categories.forEach((c: string) => categorySet.add(c)));
const allCategories = [...categorySet].sort();
const categoryCount = allCategories.length;

const allScholars = await getCollection('scholars');
const scholarNameMap = new Map(allScholars.map(s => [s.id, s.data.name]));

// For the hero display text
const scholarsList = allScholars.map(s => ({ slug: s.id, name: s.data.name }));
const otherScholarsCount = scholarCount - 3;
const topThree = scholarsList.slice(0, 3).map(s => s.name.replace('Shaykh ', '').split(' ')[0]).join(', ');
---

<Layout title="Home">
  <Hero
    rulingsCount={fatwaCount}
    scholarsCount={scholarCount}
    categoriesCount={categoryCount}
    scholars={scholarsList}
    categories={allCategories}
  />

  <div class="list-head">Recent rulings</div>

  <div id="fatwa-list">
    {allFatwas.map(fatwa => {
      const fullName = scholarNameMap.get(fatwa.data.scholar) || fatwa.data.scholar;
      const shortName = fullName.split(' ').pop();
      const firstCat = fatwa.data.categories.length > 0 ? fatwa.data.categories[0] : null;
      return (
        <a
          href={`/fatwa/${fatwa.id}`}
          class="fatwa-row"
          data-scholar={fatwa.data.scholar}
          data-categories={fatwa.data.categories.map((c: string) => c.toLowerCase().replace(/\s+/g, '-')).join(',')}
          data-title={fatwa.data.title || `Fatwa #${fatwa.id}`}
          data-body={fatwa.data.question ? fatwa.data.question.replace(/\n/g, ' ') : ''}
        >
          <span class="row-date">{fatwa.data.date_added.toLocaleDateString()}</span>
          <div class="row-title-wrap">
            <span class="row-title">{fatwa.data.title || `Fatwa #${fatwa.id}`}</span>
            {firstCat && <span class="row-cat">{firstCat}</span>}
          </div>
          <span class="row-scholar">{shortName}</span>
        </a>
      );
    })}
  </div>

  <p id="empty-state" class="hidden text-center py-12 text-[var(--text-muted)]">No fatwas match the current filters.</p>
</Layout>

<style>
  .list-head {
    font-family: var(--font-ui);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.75rem 2rem 0.35rem;
  }
  .fatwa-row {
    display: grid;
    grid-template-columns: 90px 1fr 120px;
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.9rem 2rem;
    border-bottom: 1px solid var(--border-default);
    cursor: pointer;
    text-decoration: none;
    border-radius: 0;
    transition: background var(--transition);
  }
  .fatwa-row:hover {
    background: var(--bg-hover);
  }
  .row-date {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.03em;
  }
  .row-title-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.3rem;
  }
  .row-title {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.4;
  }
  .row-cat {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 9px;
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    background: var(--bg-pill);
    color: var(--accent);
    border: 1px solid var(--accent-light);
    font-style: normal;
    vertical-align: middle;
    letter-spacing: 0.03em;
  }
  .row-scholar {
    font-family: var(--font-ui);
    font-size: 10px;
    color: var(--text-muted);
    text-align: right;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>

<script>
  // Combine search text and filter pills
  const searchInput = document.getElementById('hero-search') as HTMLInputElement | null;
  const items = document.querySelectorAll('.fatwa-row');
  const emptyState = document.getElementById('empty-state');

  function getActiveFilter(type: string): string {
    const active = document.querySelector(`.filter-pill[data-filter-type="${type}"].active`);
    return active ? active.getAttribute('data-filter-value') || '' : '';
  }

  function applyFilters(): void {
    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
    const scholarFilter = getActiveFilter('scholar');
    const categoryFilter = getActiveFilter('category');

    let visible = 0;
    items.forEach((item) => {
      const el = item as HTMLElement;
      const matchesScholar = !scholarFilter || el.getAttribute('data-scholar') === scholarFilter;
      const matchesCategory = !categoryFilter || (el.getAttribute('data-categories') || '').split(',').includes(categoryFilter);
      const matchesText = !searchTerm ||
        (el.getAttribute('data-title')?.toLowerCase().includes(searchTerm)) ||
        (el.getAttribute('data-body')?.toLowerCase().includes(searchTerm));

      const show = matchesScholar && matchesCategory && matchesText;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
  }

  // Debounce search input
  let debounceTimer: ReturnType<typeof setTimeout> | undefined;
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(applyFilters, 220);
    });
  }

  // Listen for filter pill clicks (they already change active class via Hero's script)
  document.addEventListener('click', (e: MouseEvent) => {
    const target = e.target as HTMLElement | null;
    if (target && target.classList && target.classList.contains('filter-pill')) {
      setTimeout(applyFilters, 10);
    }
  });

  // Initial filter application
  applyFilters();
</script>