---
const { question, answer, arabicQuestion, arabicAnswer } = Astro.props;
---

<section class="mb-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
    <article class="prose prose-fatwa max-w-none">
      <h2>Question</h2>
      <p>{question}</p>

      <h2 class="mt-6">Answer</h2>
      <p>{answer}</p>
    </article>

    <aside class="arabic-text prose max-w-none">
      <h2 class="font-arabic">السؤال</h2>
      <p>{arabicQuestion || '—'}</p>

      <h2 class="font-arabic mt-6">الجواب</h2>
      <p>{arabicAnswer || '—'}</p>
    </aside>
  </div>
</section>
